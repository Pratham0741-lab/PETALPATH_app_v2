datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  name                 String
  provider             String    @default("email") // google, email
  googleId             String?   @map("google_id")
  profilePicture       String?   @map("profile_picture")
  passwordHash         String?   @map("password_hash")
  resetPasswordToken   String?   @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")
  role                 String    @default("PARENT") // PARENT, ADMIN, MENTOR
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  children      Child[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Child {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  age       Int
  ageGroup  String    @map("age_group")
  avatar    String
  mentorId  String?   @map("mentor_id")
  mentor    Mentor?   @relation(fields: [mentorId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  lessonProgress   LessonProgress[]
  rewards          Reward[]
  stories          Story[]
  questionnaires   Questionnaire[]
  videoProgress    VideoProgress[]
  listenProgress   ListenProgress[]
  speakProgress    SpeakProgress[]
  writeProgress    WriteProgress[]
  stars            Stars?
  childStickers    ChildSticker[]
  childBadges      ChildBadge[]
  moduleProgress   ModuleProgress[]
  categoryProgress CategoryProgress[]
  skillHealths        SkillHealth[]
  skillHistories      SkillHistory[]
  regressionLogs      RegressionLog[]
  reinforcementQueues    ReinforcementQueue[]
  reinforcementHistories ReinforcementHistory[]
  reinforcementEvents    ReinforcementEvent[]
  childSkillCurriculums  ChildSkillCurriculum[]
  learningProfile        LearningProfile?
  modalityPerformances   ModalityPerformance[]
  adaptationEvents       AdaptationEvent[]
  learningEvents         LearningEvent[]
  sessionPlans           SessionPlan[]
  analyticsSnapshot      AnalyticsSnapshot?
  analyticsHistories     AnalyticsHistory[]
  trendEvents            TrendEvent[]
  subjectAnalytics       SubjectAnalytics[]

  @@map("children")
}

model Mentor {
  id            String    @id @default(uuid())
  name          String
  characterType String    @map("character_type")
  personality   String
  voiceStyle    String    @map("voice_style")
  description   String
  iconKey       String    @map("image_path")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  children Child[]

  @@map("mentors")
}

model Category {
  id           String    @id @default(uuid())
  title        String    @unique
  description  String?
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  modules          Module[]
  categoryProgress CategoryProgress[]

  @@map("categories")
}

model Module {
  id           String    @id @default(uuid())
  categoryId   String    @map("category_id")
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  lessons        Lesson[]
  moduleProgress ModuleProgress[]

  @@map("modules")
}

model Lesson {
  id           String    @id @default(uuid())
  moduleId     String    @map("module_id")
  module       Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  displayOrder Int       @default(0) @map("display_order")
  difficulty   String    @default("EASY")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  activities     Activity[]
  lessonProgress LessonProgress[]

  @@map("lessons")
}

model Activity {
  id           String    @id @default(uuid())
  lessonId     String    @map("lesson_id")
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  activityType String    @map("activity_type")
  contentUrl   String?
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  video          Video?
  audio          Audio?
  listenProgress ListenProgress[]
  speakProgress  SpeakProgress[]
  writeProgress  WriteProgress[]

  @@map("activities")
}

model Video {
  id           String          @id @default(uuid())
  activityId   String          @unique @map("activity_id")
  activity     Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title        String
  videoKey     String          @map("filename")
  thumbnailKey String?         @map("thumbnail")
  duration     Int             @default(0)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  progressions VideoProgress[]

  @@map("videos")
}

model VideoProgress {
  id            String   @id @default(uuid())
  childId       String   @map("child_id")
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  videoId       String   @map("video_id")
  video         Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  watchPosition Int      @default(0) @map("watch_position")
  isCompleted   Boolean  @default(false) @map("is_completed")
  lastWatchedAt DateTime @default(now()) @map("last_watched_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([childId, videoId])
  @@map("video_progress")
}

model LessonProgress {
  id              String    @id @default(uuid())
  childId         String
  child           Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status          String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  videoCompleted  Boolean   @default(false) @map("video_completed")
  listenCompleted Boolean   @default(false) @map("listen_completed")
  speakCompleted  Boolean   @default(false) @map("speak_completed")
  writeCompleted  Boolean   @default(false) @map("write_completed")
  videoStars      Int       @default(0) @map("video_stars")
  listenStars     Int       @default(0) @map("listen_stars")
  speakStars      Int       @default(0) @map("speak_stars")
  writeStars      Int       @default(0) @map("write_stars")
  totalStars      Int       @default(0) @map("total_stars")
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@unique([childId, lessonId])
}

model Reward {
  id          String    @id @default(uuid())
  childId     String
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  title       String
  description String?
  points      Int       @default(0)
  earnedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model Story {
  id           String    @id @default(uuid())
  childId      String
  child        Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  title        String
  content      String
  audioKey     String?   @map("audioUrl")
  thumbnailKey String?   @map("imageUrl")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
}

model Questionnaire {
  id        String    @id @default(uuid())
  childId   String
  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  responses Json
  score     Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model Audio {
  id         String   @id @default(uuid())
  activityId String   @unique @map("activity_id")
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  title      String
  audioKey   String   @map("filename")
  duration   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("audios")
}

model ListenProgress {
  id           String   @id @default(uuid())
  childId      String   @map("child_id")
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId   String   @map("activity_id")
  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  isCompleted  Boolean  @default(false) @map("is_completed")
  attemptCount Int      @default(0) @map("attempt_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([childId, activityId])
  @@map("listen_progress")
}

model SpeakProgress {
  id           String   @id @default(uuid())
  childId      String   @map("child_id")
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId   String   @map("activity_id")
  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  isCompleted  Boolean  @default(false) @map("is_completed")
  attemptCount Int      @default(0) @map("attempt_count")
  bestScore    Float    @default(0.0) @map("best_score")
  averageScore Float    @default(0.0) @map("average_score")
  bestStars    Int      @default(0) @map("best_stars")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([childId, activityId])
  @@map("speak_progress")
}

model WriteProgress {
  id           String   @id @default(uuid())
  childId      String   @map("child_id")
  child        Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId   String   @map("activity_id")
  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  isCompleted  Boolean  @default(false) @map("is_completed")
  attemptCount Int      @default(0) @map("attempt_count")
  bestScore    Float    @default(0.0) @map("best_score")
  averageScore Float    @default(0.0) @map("average_score")
  bestStars    Int      @default(0) @map("best_stars")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([childId, activityId])
  @@map("write_progress")
}

model Stars {
  id         String   @id @default(uuid())
  childId    String   @unique @map("child_id")
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  totalStars Int      @default(0) @map("total_stars")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("stars")
}

model Sticker {
  id            String         @id @default(uuid())
  name          String
  description   String?
  iconKey       String         @map("image_path")
  requiredStars Int            @map("required_stars")
  childStickers ChildSticker[]

  @@map("stickers")
}

model ChildSticker {
  id         String   @id @default(uuid())
  childId    String   @map("child_id")
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  stickerId  String   @map("sticker_id")
  sticker    Sticker  @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  @@unique([childId, stickerId])
  @@map("child_stickers")
}

model Badge {
  id          String       @id @default(uuid())
  name        String
  description String?
  iconKey     String       @map("image_path")
  childBadges ChildBadge[]

  @@map("badges")
}

model ChildBadge {
  id       String   @id @default(uuid())
  childId  String   @map("child_id")
  child    Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  badgeId  String   @map("badge_id")
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now()) @map("earned_at")

  @@unique([childId, badgeId])
  @@map("child_badges")
}

model ModuleProgress {
  id               String    @id @default(uuid())
  childId          String    @map("child_id")
  child            Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  moduleId         String    @map("module_id")
  module           Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completedLessons Int       @default(0) @map("completed_lessons")
  isCompleted      Boolean   @default(false) @map("is_completed")
  completedAt      DateTime? @map("completed_at")

  @@unique([childId, moduleId])
  @@map("module_progress")
}

model CategoryProgress {
  id               String    @id @default(uuid())
  childId          String    @map("child_id")
  child            Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  categoryId       String    @map("category_id")
  category         Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  completedModules Int       @default(0) @map("completed_modules")
  isCompleted      Boolean   @default(false) @map("is_completed")
  completedAt      DateTime? @map("completed_at")

  @@unique([childId, categoryId])
  @@map("category_progress")
}

enum MasteryState {
  NEW
  LEARNING
  WEAK
  STRONG
  MASTERED
}

model Skill {
  id                  String               @id @default(uuid())
  subjectId           String               @map("subject_id")
  subject             Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  name                String               @unique
  description         String?
  difficulty          Int                  @default(1)
  estimatedAge        Int?                 @map("estimated_age")
  isRootSkill         Boolean              @default(false) @map("is_root_skill")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  skillHealths        SkillHealth[]
  skillHistories      SkillHistory[]
  parentDependencies  SkillDependency[]    @relation("ParentSkill")
  childDependencies   SkillDependency[]    @relation("ChildSkill")
  regressionLogs      RegressionLog[]
  reinforcementQueues    ReinforcementQueue[]
  reinforcementHistories ReinforcementHistory[]
  reinforcementEvents    ReinforcementEvent[]
  childSkillCurriculums  ChildSkillCurriculum[]
  sessionBlocks          SessionBlock[]

  @@map("skills")
}

model SkillDependency {
  id            String   @id @default(uuid())
  parentSkillId String   @map("parent_skill_id")
  childSkillId  String   @map("child_skill_id")
  weight        Float
  createdAt     DateTime @default(now()) @map("created_at")

  parentSkill Skill @relation("ParentSkill", fields: [parentSkillId], references: [id], onDelete: Cascade)
  childSkill  Skill @relation("ChildSkill", fields: [childSkillId], references: [id], onDelete: Cascade)

  @@unique([parentSkillId, childSkillId])
  @@map("skill_dependencies")
}

model SkillHealth {
  id               String       @id @default(uuid())
  childId          String       @map("child_id")
  child            Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId          String       @map("skill_id")
  skill            Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  masteryState     MasteryState @map("mastery_state")
  knowledgeScore   Float        @map("knowledge_score")
  confidenceScore  Float        @map("confidence_score")
  retentionScore   Float        @map("retention_score")
  engagementScore  Float        @map("engagement_score")
  consistencyScore Float        @map("consistency_score")
  masteryScore     Float        @map("mastery_score")
  lastPracticed    DateTime     @map("last_practiced")
  nextReviewDate   DateTime     @map("next_review_date")
  reviewCount      Int          @map("review_count")
  attemptCount     Int          @map("attempt_count")
  retryCount       Int          @map("retry_count")
  decayFactor      Float        @map("decay_factor")
  frequencyDays    Int          @map("frequency_days")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@unique([childId, skillId])
  @@map("skill_health")
}

model SkillHistory {
  id               String       @id @default(uuid())
  childId          String       @map("child_id")
  child            Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId          String       @map("skill_id")
  skill            Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  knowledgeScore   Float        @map("knowledge_score")
  confidenceScore  Float        @map("confidence_score")
  retentionScore   Float        @map("retention_score")
  engagementScore  Float        @map("engagement_score")
  consistencyScore Float        @map("consistency_score")
  masteryScore     Float        @map("mastery_score")
  masteryState     MasteryState @map("mastery_state")
  timestamp        DateTime     @default(now())

  @@map("skill_history")
}

model RegressionLog {
  id            String       @id @default(uuid())
  childId       String       @map("child_id")
  child         Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId       String       @map("skill_id")
  skill         Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  previousScore Float        @map("previous_score")
  currentScore  Float        @map("current_score")
  difference    Float        @default(0.0) @map("difference")
  previousState MasteryState @map("previous_state")
  currentState  MasteryState @map("current_state")
  timestamp     DateTime     @default(now())

  @@map("regression_logs")
}

model ReinforcementQueue {
  id             String       @id @default(uuid())
  childId        String       @map("child_id")
  child          Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId        String       @map("skill_id")
  skill          Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  priority       Float
  masteryState   MasteryState @default(LEARNING) @map("mastery_state")
  reason         String
  isCompleted    Boolean      @default(false) @map("is_completed")
  nextReviewDate DateTime     @map("next_review_date")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([childId, skillId])
  @@index([childId])
  @@index([childId, isCompleted])
  @@index([nextReviewDate])
  @@index([priority])
  @@map("reinforcement_queue")
}

enum CurriculumState {
  LOCKED
  AVAILABLE
  ACTIVE
  COMPLETED
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  skills      Skill[]
  sessionBlocks SessionBlock[]
  subjectAnalytics SubjectAnalytics[]

  @@map("subjects")
}

model ChildSkillCurriculum {
  id          String          @id @default(uuid())
  childId     String          @map("child_id")
  child       Child           @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId     String          @map("skill_id")
  skill       Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  state       CurriculumState @map("state")
  unlockRatio Float           @map("unlock_ratio")
  priority    Float           @map("priority")
  activatedAt DateTime?       @map("activated_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([childId, skillId])
  @@map("child_skill_curriculum")
}

enum ActivityType {
  VIDEO
  LISTENING
  SPEAKING
  GAME
  WRITING
  STORY
  MOTOR
  CREATIVE
  WARMUP
  REWARD
}

enum ReinforcementEventType {
  REVIEW_TRIGGERED
  REVIEW_COMPLETED
  RETENTION_DROP
  REINFORCEMENT_SUCCESS
  REINFORCEMENT_FAILED
}

enum AdaptationEventType {
  MODALITY_CHANGE
  SESSION_SHORTENED
  SESSION_EXTENDED
  WEAKNESS_DETECTED
  STRENGTH_DETECTED
  REINFORCEMENT_ADDED
  REGRESSION_DETECTED
  CONFIDENCE_DROP
  CONFIDENCE_IMPROVEMENT
  ENGAGEMENT_DROP
  ENGAGEMENT_IMPROVEMENT
}

model LearningProfile {
  id                     String       @id @default(uuid())
  childId                String       @unique @map("child_id")
  child                  Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  averageAccuracy        Float        @map("average_accuracy")
  averageEngagement      Float        @map("average_engagement")
  averageConfidence      Float        @map("average_confidence")
  optimalSessionDuration Int          @map("optimal_session_duration")
  preferredModality      ActivityType @map("preferred_modality")
  learningVelocity       Float        @map("learning_velocity")
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  @@map("learning_profiles")
}

model ModalityPerformance {
  id                String       @id @default(uuid())
  childId           String       @map("child_id")
  child             Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityType      ActivityType @map("activity_type")
  attempts          Int          @map("attempts")
  averageAccuracy   Float        @map("average_accuracy")
  averageEngagement Float        @map("average_engagement")
  averageConfidence Float        @map("average_confidence")
  lastUsedAt        DateTime     @map("last_used_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@unique([childId, activityType])
  @@index([childId])
  @@map("modality_performances")
}

model AdaptationEvent {
  id        String              @id @default(uuid())
  childId   String              @map("child_id")
  child     Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  eventType AdaptationEventType @map("event_type")
  reason    String              @map("reason")
  metadata  Json?               @map("metadata")
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([childId])
  @@index([childId, eventType])
  @@map("adaptation_events")
}

model LearningEvent {
  id        String   @id @default(uuid())
  childId   String   @map("child_id")
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type")
  value     Float?   @map("value")
  metadata  Json?    @map("metadata")
  timestamp DateTime @default(now()) @map("timestamp")

  @@index([childId])
  @@index([childId, eventType])
  @@map("learning_events")
}

model ReinforcementHistory {
  id              String       @id @default(uuid())
  childId         String       @map("child_id")
  child           Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId         String       @map("skill_id")
  skill           Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  activityType    ActivityType @map("activity_type")
  beforeScore     Float        @map("before_score")
  afterScore      Float        @map("after_score")
  scoreDifference Float        @map("score_difference")
  success         Boolean
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([childId])
  @@index([childId, skillId])
  @@map("reinforcement_history")
}

model ReinforcementEvent {
  id        String                   @id @default(uuid())
  childId   String                   @map("child_id")
  child     Child                    @relation(fields: [childId], references: [id], onDelete: Cascade)
  skillId   String                   @map("skill_id")
  skill     Skill                    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  eventType ReinforcementEventType   @map("event_type")
  metadata  Json?                    @map("metadata")
  createdAt DateTime                 @default(now()) @map("created_at")

  @@index([childId])
  @@index([childId, skillId])
  @@index([childId, eventType])
  @@map("reinforcement_events")
}

enum SessionStatus {
  GENERATED
  STARTED
  PAUSED
  COMPLETED
  ABANDONED
}

enum SessionBlockStatus {
  PENDING
  STARTED
  COMPLETED
  SKIPPED
}

enum SessionEventType {
  GENERATED
  STARTED
  PAUSED
  RESUMED
  BLOCK_COMPLETED
  BLOCK_SKIPPED
  COMPLETED
  ABANDONED
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

model SessionTemplate {
  id              String   @id @default(uuid())
  name            String
  durationMinutes Int      @map("duration_minutes")
  blockSequence   Json     @map("block_sequence") // stores array of objects: { activityType: string, estimatedMinutes: number }
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("session_templates")
}

model SessionPlan {
  id              String         @id @default(uuid())
  childId         String         @map("child_id")
  child           Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  durationMinutes Int            @map("duration_minutes")
  status          SessionStatus  @default(GENERATED)
  startedAt       DateTime?      @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  sessionBlocks   SessionBlock[]
  sessionEvents   SessionEvent[]

  @@index([childId])
  @@index([status])
  @@index([createdAt])
  @@map("session_plans")
}

model SessionBlock {
  id               String             @id @default(uuid())
  sessionPlanId    String             @map("session_plan_id")
  sessionPlan      SessionPlan        @relation(fields: [sessionPlanId], references: [id], onDelete: Cascade)
  skillId          String?            @map("skill_id")
  skill            Skill?             @relation(fields: [skillId], references: [id], onDelete: SetNull)
  subjectId        String?            @map("subject_id")
  subject          Subject?           @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  activityType     ActivityType       @map("activity_type")
  difficulty       DifficultyLevel
  estimatedMinutes Int                @map("estimated_minutes")
  position         Int
  status           SessionBlockStatus @default(PENDING)
  completedAt      DateTime?          @map("completed_at")
  createdAt        DateTime           @default(now()) @map("created_at")

  @@index([sessionPlanId])
  @@index([position])
  @@index([skillId])
  @@map("session_blocks")
}

model SessionEvent {
  id            String           @id @default(uuid())
  sessionPlanId String           @map("session_plan_id")
  sessionPlan   SessionPlan      @relation(fields: [sessionPlanId], references: [id], onDelete: Cascade)
  eventType     SessionEventType @map("event_type")
  metadata      Json?            @map("metadata")
  createdAt     DateTime         @default(now()) @map("created_at")

  @@index([sessionPlanId])
  @@index([eventType])
  @@map("session_events")
}

enum AnalyticsMetricType {
  ACCURACY
  CONFIDENCE
  RETENTION
  ENGAGEMENT
  LEARNING_VELOCITY
  SESSION_COMPLETION
  REINFORCEMENT_SUCCESS
}

enum TrendEventType {
  CONFIDENCE_IMPROVING
  CONFIDENCE_DECLINING
  RETENTION_IMPROVING
  RETENTION_DECLINING
  ENGAGEMENT_IMPROVING
  ENGAGEMENT_DECLINING
  LEARNING_ACCELERATING
  LEARNING_SLOWING
  SESSION_ABANDONMENT
  REGRESSION_DETECTED
}

model AnalyticsSnapshot {
  id                         String   @id @default(uuid())
  childId                    String   @unique @map("child_id")
  child                      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  accuracy                   Float
  confidence                 Float
  retention                  Float
  engagement                 Float
  learningVelocity           Float    @map("learning_velocity")
  sessionCompletionRate      Float    @map("session_completion_rate")
  reinforcementSuccessRate   Float    @map("reinforcement_success_rate")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@index([childId])
  @@map("analytics_snapshots")
}

model AnalyticsHistory {
  id         String              @id @default(uuid())
  childId    String              @map("child_id")
  child      Child               @relation(fields: [childId], references: [id], onDelete: Cascade)
  metricType AnalyticsMetricType @map("metric_type")
  value      Float
  timestamp  DateTime            @default(now())

  @@unique([childId, metricType, timestamp])
  @@index([childId])
  @@index([metricType])
  @@index([timestamp])
  @@map("analytics_histories")
}

model TrendEvent {
  id        String         @id @default(uuid())
  childId   String         @map("child_id")
  child     Child          @relation(fields: [childId], references: [id], onDelete: Cascade)
  eventType TrendEventType @map("event_type")
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([childId])
  @@index([eventType])
  @@map("trend_events")
}

model SubjectAnalytics {
  id               String   @id @default(uuid())
  childId          String   @map("child_id")
  child            Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  subjectId        String   @map("subject_id")
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  accuracy         Float
  confidence       Float
  retention        Float
  progress         Float
  learningVelocity Float    @map("learning_velocity")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([childId, subjectId])
  @@index([childId])
  @@index([subjectId])
  @@map("subject_analytics")
}



