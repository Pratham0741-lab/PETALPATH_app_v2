{
  "expo": {
    "name": "petalpath_app_v2",
    "slug": "petalpath_app_v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.petalpath_app_v2"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.244358134848-cblimclem7n3knhsu6ahu29kd7l0pqve"
        }
      ],
      "expo-video",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow PetalPath to use the microphone for speech activities.",
          "speechRecognitionPermission": "Allow PetalPath to use speech recognition for learning activities."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
