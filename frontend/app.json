{
  "expo": {
    "name": "petalpath_app_v2",
    "slug": "petalpath_app_v2",
    "scheme": "petalpath",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow PetalPath to use speech recognition for learning activities.",
        "NSMicrophoneUsageDescription": "Allow PetalPath to use the microphone for speech activities."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.petalpath_app_v2",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "./plugins/withAndroidNetworkSecurity",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.244358134848-cblimclem7n3knhsu6ahu29kd7l0pqve"
        }
      ],
      "expo-video",
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow PetalPath to use the microphone for speech activities.",
          "speechRecognitionPermission": "Allow PetalPath to use speech recognition for learning activities."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "22bc5504-842c-4282-b770-b1f26f3d79f8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/22bc5504-842c-4282-b770-b1f26f3d79f8"
    }
  }
}
